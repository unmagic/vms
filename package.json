{
  "name": "@unmagic/vms",
  "version": "0.1.6-beta.0",
  "description": "基于 @unmagic/vue-mini 的Vue3 单文件组件构建工具",
  "type": "module",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22.17.1"
  },
  "keywords": [
    "vms",
    "WeChat",
    "mini-program",
    "@vue-mini",
    "SFC"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unmagic/vms.git"
  },
  "bin": {
    "vms": "bin/index.js"
  },
  "scripts": {
    "example:dev": "cd example && npm run dev",
    "example:build": "cd example && npm run build",
    "example:inspect": "cd example && npm run inspect:vms",
    "vms:build": "rolldown --config rolldown.config.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "publish:ci": "npm publish",
    "link": "pnpm link --global",
    "lint": "oxlint ./src",
    "format": "oxfmt --check \"**/*.{js,cjs,ts,json,md}\"",
    "release": "tsx release.ts",
    "prepare": "husky"
  },
  "files": [
    "dist",
    "bin"
  ],
  "peerDependencies": {
    "@unmagic/vue-mini": ">=1.0.3"
  },
  "devDependencies": {
    "@types/babel__code-frame": "^7.27.0",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@vue/reactivity": "3.5.33",
    "execa": "^9.6.1",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "miniprogram-api-typings": "5.1.3",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@babel/code-frame": "^7.29.0",
    "@babel/core": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.3",
    "@babel/plugin-transform-arrow-functions": "^7.27.1",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/plugin-transform-template-literals": "^7.27.1",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@vue/compiler-core": "3.5.33",
    "@vue/compiler-dom": "3.5.33",
    "@vue/compiler-sfc": "3.5.33",
    "babel-plugin-autocomplete-index": "^0.2.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "cross-env": "^10.1.0",
    "dotenv-flow": "^4.1.0",
    "fs-extra": "^11.3.4",
    "kolorist": "^1.8.0",
    "local-pkg": "^1.1.2",
    "miniprogram-ci": "^2.1.31",
    "rolldown": "^1.0.0",
    "terser": "^5.46.2",
    "tinycolor2": "^1.6.0"
  }
}
